rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function memberPath(programId) { return /databases/$(database)/documents/programs/$(programId)/members/$(request.auth.uid); }
    function isMember(programId) { return signedIn() && exists(memberPath(programId)) && get(memberPath(programId)).data.active == true; }
    function isAdmin(programId) { return isMember(programId) && get(memberPath(programId)).data.role == 'admin'; }
    function positiveSen(value) { return value is int && value > 0; }
    function registrationOpen(programId) { return !exists(/databases/$(database)/documents/programs/$(programId)/public/event) || get(/databases/$(database)/documents/programs/$(programId)/public/event).data.registrationEnabled != false; }
    function registrationCounterPath(programId) { return /databases/$(database)/documents/programs/$(programId)/counters/registrations; }
    function validPublicCounterCreate() {
      return request.resource.data.value == 1
        && request.resource.data.get('day1', 0) + request.resource.data.get('full', 0) == 1
        && request.resource.data.get('day1', 0) <= 150
        && request.resource.data.get('full', 0) <= 15;
    }
    function validPublicCounterUpdate() {
      return request.resource.data.value == resource.data.value + 1
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['value','day1','full','updatedAt'])
        && request.resource.data.get('day1', 0) <= 150
        && request.resource.data.get('full', 0) <= 15
        && ((request.resource.data.get('day1', 0) == resource.data.get('day1', 0) + 1
          && request.resource.data.get('full', 0) == resource.data.get('full', 0))
          || (request.resource.data.get('full', 0) == resource.data.get('full', 0) + 1
          && request.resource.data.get('day1', 0) == resource.data.get('day1', 0)));
    }
    function registrationCounterAdvanced(programId, attendanceType) {
      let path = registrationCounterPath(programId);
      let before = exists(path) ? get(path).data : {};
      let after = getAfter(path).data;
      return after.value == before.get('value', 0) + 1
        && after.get('day1', 0) <= 150
        && after.get('full', 0) <= 15
        && ((attendanceType == 'day1'
          && after.get('day1', 0) == before.get('day1', 0) + 1
          && after.get('full', 0) == before.get('full', 0))
          || (attendanceType == 'full'
          && after.get('full', 0) == before.get('full', 0) + 1
          && after.get('day1', 0) == before.get('day1', 0)));
    }
    function validTransaction(programId) {
      return request.resource.data.programId == programId
        && request.resource.data.type in ['income','expense','refund','adjustment']
        && request.resource.data.status in ['pending','approved','paid','cancelled']
        && positiveSen(request.resource.data.amountInSen)
        && request.resource.data.description is string
        && request.resource.data.description.size() > 0
        && !request.resource.data.keys().hasAny(['totalIncome','totalExpenses','currentBalance','budgetRemaining']);
    }
    function validPublicRegistration(programId) {
      return signedIn()
        && request.resource.data.keys().hasAll(['id','programId','ownerUid','referenceNumber','fullName','identificationNumber','email','phoneNumber','organisationType','workplace','expertise','foodPreference','attendanceType','attendanceLabel','registrationFeeInSen','paymentStatus','registrationStatus','privacyConsent','informationConfirmation','termsAccepted','createdAt','updatedAt'])
        && request.resource.data.programId == programId
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.id is string
        && request.resource.data.referenceNumber is string
        && request.resource.data.fullName is string
        && request.resource.data.identificationNumber is string
        && request.resource.data.email is string && request.resource.data.phoneNumber is string
        && request.resource.data.attendanceType in ['day1','full']
        && ((request.resource.data.attendanceType == 'day1' && request.resource.data.registrationFeeInSen == 15000) || (request.resource.data.attendanceType == 'full' && request.resource.data.registrationFeeInSen == 30000))
        && request.resource.data.paymentStatus == 'pending_verification'
        && request.resource.data.registrationStatus == 'submitted'
        && request.resource.data.privacyConsent == true
        && request.resource.data.informationConfirmation == true
        && request.resource.data.termsAccepted == true
        && request.resource.data.linkedTransactionId == null
        && registrationCounterAdvanced(programId, request.resource.data.attendanceType);
    }

    match /programs/{programId} {
      allow read: if isMember(programId);
      allow create, delete: if false;
      allow update: if isAdmin(programId) && !request.resource.data.keys().hasAny(['totalIncome','totalExpenses','currentBalance','budgetRemaining']);

      match /public/{documentId} { allow read: if true; allow write: if isAdmin(programId); }
      match /members/{userId} {
        allow read: if isMember(programId) || (signedIn() && userId == request.auth.uid);
        allow create: if isAdmin(programId) && request.resource.data.role in ['admin','viewer'] && request.resource.data.active is bool;
        allow update: if isAdmin(programId) && userId != request.auth.uid && request.resource.data.role in ['admin','viewer'] && request.resource.data.active is bool;
        allow delete: if isAdmin(programId) && userId != request.auth.uid;
      }
      match /accessRequests/{userId} {
        allow read: if isAdmin(programId) || (signedIn() && userId == request.auth.uid);
        allow create: if signedIn() && request.auth.uid == userId && request.auth.token.firebase.sign_in_provider != 'anonymous'
          && request.resource.data.uid == request.auth.uid && request.resource.data.status == 'pending'
          && request.resource.data.requestedRole == 'viewer' && request.resource.data.email is string;
        allow update: if (isAdmin(programId) && request.resource.data.uid == resource.data.uid && request.resource.data.email == resource.data.email)
          || (signedIn() && request.auth.uid == userId && request.auth.token.firebase.sign_in_provider != 'anonymous'
            && request.resource.data.uid == resource.data.uid
            && request.resource.data.status == 'pending'
            && request.resource.data.requestedRole == 'viewer'
            && request.resource.data.email is string
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['email','fullName','status','requestedRole','requestedAt','updatedAt']));
        allow delete: if false;
      }
      match /transactions/{id} {
        allow read: if isMember(programId);
        allow create: if isAdmin(programId) && validTransaction(programId) && request.resource.data.createdBy == request.auth.uid;
        allow update: if isAdmin(programId) && validTransaction(programId) && request.resource.data.createdBy == resource.data.createdBy && request.resource.data.createdAt == resource.data.createdAt && request.resource.data.updatedBy == request.auth.uid;
        allow delete: if false;
      }
      match /categories/{id} { allow read: if isMember(programId); allow create, update: if isAdmin(programId) && request.resource.data.name is string && request.resource.data.active is bool; allow delete: if false; }
      match /budgets/{id} { allow read: if isMember(programId); allow create, update: if isAdmin(programId) && positiveSen(request.resource.data.allocatedAmountInSen); allow delete: if isAdmin(programId); }
      match /registrations/{registrationId} {
        allow read: if isAdmin(programId) || (signedIn() && resource.data.ownerUid == request.auth.uid);
        allow create: if validPublicRegistration(programId);
        allow update: if isAdmin(programId) || (signedIn() && resource.data.ownerUid == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['proofOfPaymentPath','updatedAt']) && resource.data.proofOfPaymentPath == '');
        allow delete: if isAdmin(programId)
          && (resource.data.linkedTransactionId == null
            || getAfter(/databases/$(database)/documents/programs/$(programId)/transactions/$(resource.data.linkedTransactionId)).data.status == 'cancelled');
      }
      match /counters/registrations {
        allow read: if signedIn();
        allow create: if signedIn() && validPublicCounterCreate();
        allow update: if isAdmin(programId) || (signedIn() && validPublicCounterUpdate());
        allow delete: if false;
      }
    }
  }
}
